{
  "name": "@gnireeg/accordion",
  "version": "0.1.9",
  "description": "Accessible accordion web component with smooth animations, keyboard support, and nested accordion groups",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": ["dist/global.d.ts", "dist/index.d.ts"]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "accordion",
    "web-components",
    "custom-elements",
    "accessible",
    "a11y",
    "typescript",
    "ui-components"
  ],
  "author": "Joel Geering <joel@geering.dev> (https://geering.dev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gnireeG/web-components.git",
    "directory": "packages/accordion"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('src/global.d.ts', 'dist/global.d.ts')\"",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}